{
  "enabled": true,
  "name": "Run Tests on Change",
  "description": "Runs Vitest test suite with coverage reporting when TypeScript files are edited to catch regressions and track test coverage",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest --run --reporter=verbose --coverage"
  }
}