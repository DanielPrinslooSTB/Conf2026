{
  "enabled": true,
  "name": "Run Tests on Change",
  "description": "Runs Vitest test suite when TypeScript files are created or edited to catch regressions immediately",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest --run"
  }
}