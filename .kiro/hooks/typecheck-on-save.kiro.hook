{
  "enabled": true,
  "name": "Type-check on Save",
  "description": "Runs TypeScript compiler in strict mode on save to catch type errors before they propagate",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx tsc --noEmit --strict"
  }
}