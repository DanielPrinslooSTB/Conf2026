{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs ESLint on TypeScript files whenever they are saved to enforce code style and catch issues early",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx eslint --fix ${file}"
  }
}