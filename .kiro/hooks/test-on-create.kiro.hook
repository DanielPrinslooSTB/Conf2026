{
  "enabled": true,
  "name": "Run Tests on Create",
  "description": "Runs Vitest test suite with coverage reporting when new TypeScript files are created to ensure new code has passing tests and coverage from the start",
  "version": "1",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest --run --reporter=verbose --coverage"
  }
}