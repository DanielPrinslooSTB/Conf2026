{
  "mcpServers": {
    "prisma": {
      "command": "npx",
      "args": ["-y", "prisma-mcp-server"],
      "env": {
        "DATABASE_URL": "file:./server/prisma/dev.db"
      },
      "disabled": false,
      "autoApprove": []
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-figma"],
      "env": {
        "FIGMA_ACCESS_TOKEN": ""
      },
      "disabled": true,
      "autoApprove": []
    },
    "docs-server": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
